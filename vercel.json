{
  "rewrites": [
    {
      "source": "/user",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": {
            "re": ".*([fF]acebook|[tT]witter|[wW]hats[aA]pp|[lL]inked[iI]n|[tT]elegram|[sS]lack|[dD]iscord|[gG]oogle|[bB]ing|[yY]andex|[pP]interest).*"
          }
        }
      ],
      "destination": "/api/share?type=user"
    },
    {
      "source": "/",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": {
            "re": ".*([fF]acebook|[tT]witter|[wW]hats[aA]pp|[lL]inked[iI]n|[tT]elegram|[sS]lack|[dD]iscord|[gG]oogle|[bB]ing|[yY]andex|[pP]interest).*"
          }
        }
      ],
      "destination": "/api/share?type=home"
    },
    {
      "source": "/post/:id",
      "destination": "/api/share?type=post&id=:id"
    },
    {
      "source": "/job/:id",
      "destination": "/api/share?type=job&id=:id"
    },
    {
      "source": "/form/:id",
      "destination": "/api/share?type=form&id=:id"
    },
    {
      "source": "/product/:id",
      "destination": "/api/share?type=product&id=:id"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
